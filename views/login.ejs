<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | PulseBoard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="noise-overlay"></div>
    <div class="liquid-orb one"></div>
    <div class="liquid-orb two"></div>

    <main class="relative z-10 min-h-screen px-4 py-8 md:px-10">
        <div class="mx-auto flex min-h-[85vh] w-full max-w-5xl flex-col items-center justify-center gap-6 md:gap-8">
            <div class="glass-soft fade-in flex w-full items-center justify-between rounded-2xl px-4 py-3 md:px-6">
                <p class="text-sm font-semibold tracking-wide text-slate-100 md:text-base">Welcome back to PulseBoard</p>
                <a class="btn-secondary text-sm" href="/">Create account</a>
            </div>

            <section class="grid w-full gap-6 md:grid-cols-[1.15fr,0.85fr]">
                <div class="glass-panel shine fade-in rounded-3xl p-6 md:p-8">
                    <p class="mb-3 inline-block rounded-full border border-white/20 bg-white/10 px-3 py-1 text-xs text-slate-200">Secure Session</p>
                    <h1 class="text-3xl font-bold leading-tight text-slate-50 md:text-5xl">Continue posting and managing your community moments.</h1>
                    <p class="mt-4 text-sm leading-relaxed text-slate-300">Track likes, edit your content quickly, and keep your feed active with the new liquid-glass interface.</p>
                    <div class="mt-6 flex flex-wrap gap-2">
                        <span class="stat-chip">Fast Login</span>
                        <span class="stat-chip">JWT Auth</span>
                        <span class="stat-chip">Post Reactions</span>
                    </div>
                </div>

                <div class="glass-panel fade-in rounded-3xl p-6 md:p-8">
                    <h2 class="mb-5 text-2xl font-bold text-slate-50">Login your account</h2>
                    <form method="post" action="/login" class="space-y-4">
                        <label class="block">
                            <span class="mb-1.5 block text-sm font-medium text-slate-200">Email address</span>
                            <input class="ui-input" type="email" name="email" placeholder="name@example.com" required>
                        </label>
                        <label class="block">
                            <span class="mb-1.5 block text-sm font-medium text-slate-200">Password</span>
                            <input class="ui-input" type="password" name="password" placeholder="Your password" required>
                        </label>
                        <button type="submit" class="btn-primary w-full">Login</button>
                    </form>

                    <div class="mt-5 rounded-xl border border-white/20 bg-white/10 p-3 text-sm text-slate-300">
                        Tip: Use the same credentials you created on the signup page.
                    </div>
                </div>
            </section>
        </div>
    </main>
</body>
</html>