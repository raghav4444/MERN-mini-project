<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Account | PulseBoard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="noise-overlay"></div>
    <div class="liquid-orb one"></div>
    <div class="liquid-orb two"></div>

    <main class="relative z-10 min-h-screen px-4 py-8 md:px-10">
        <div class="mx-auto flex w-full max-w-6xl flex-col gap-6 md:gap-8">
            <nav class="glass-soft fade-in flex items-center justify-between rounded-2xl px-4 py-3 md:px-6">
                <div class="flex items-center gap-3">
                    <span class="inline-flex h-8 w-8 items-center justify-center rounded-xl bg-cyan-300/30 text-sm font-bold text-cyan-100">P</span>
                    <p class="text-sm font-semibold tracking-wide text-slate-100 md:text-base">PulseBoard Mini Project</p>
                </div>
                <a class="btn-secondary text-sm" href="/login">Already a member</a>
            </nav>

            <section class="grid gap-6 md:grid-cols-2">
                <div class="glass-panel shine fade-in rounded-3xl p-6 md:p-8">
                    <p class="mb-3 inline-block rounded-full border border-white/20 bg-white/10 px-3 py-1 text-xs text-slate-200">Modern Social Feed</p>
                    <h1 class="text-3xl font-bold leading-tight text-slate-50 md:text-5xl">Build your profile and share quick posts in style.</h1>
                    <p class="mt-4 text-sm leading-relaxed text-slate-300 md:text-base">This mini project now looks production-ready with glassmorphism surfaces, layered depth, expressive actions, and mobile-friendly layout.</p>
                    <div class="mt-6 flex flex-wrap gap-2">
                        <span class="stat-chip">Liquid UI</span>
                        <span class="stat-chip">Responsive</span>
                        <span class="stat-chip">Fast Forms</span>
                        <span class="stat-chip">Tailwind + Custom CSS</span>
                    </div>
                </div>

                <div class="glass-panel fade-in rounded-3xl p-6 md:p-8">
                    <div class="mb-5 flex items-center justify-between">
                        <h2 class="text-xl font-bold text-slate-50 md:text-2xl">Create your account</h2>
                        <span class="rounded-full bg-emerald-300/20 px-2.5 py-1 text-xs font-medium text-emerald-100">Live</span>
                    </div>

                    <form method="post" action="/create" class="space-y-4">
                        <label class="block">
                            <span class="mb-1.5 block text-sm font-medium text-slate-200">Email address</span>
                            <input class="ui-input" type="email" name="email" placeholder="name@example.com" required>
                        </label>

                        <div class="grid gap-4 sm:grid-cols-2">
                            <label class="block">
                                <span class="mb-1.5 block text-sm font-medium text-slate-200">Age</span>
                                <input class="ui-input" type="number" min="1" name="age" placeholder="22" required>
                            </label>
                            <label class="block">
                                <span class="mb-1.5 block text-sm font-medium text-slate-200">Username</span>
                                <input class="ui-input" type="text" name="username" placeholder="coder_jane" required>
                            </label>
                        </div>

                        <label class="block">
                            <span class="mb-1.5 block text-sm font-medium text-slate-200">Password</span>
                            <input class="ui-input" type="password" name="password" placeholder="Create a strong password" required>
                        </label>

                        <button type="submit" class="btn-primary w-full">Create account</button>
                    </form>

                    <p class="mt-4 text-center text-sm text-slate-300">Have an account? <a href="/login" class="font-semibold text-cyan-200 hover:text-cyan-100">Login now</a></p>
                </div>
            </section>
        </div>
    </main>
</body>
</html>